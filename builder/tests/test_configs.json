[
  {
    "name": "frame_sampling_on_files",
    "description": "Test with default TensorRT and CUDA versions",
    "build_args": {
      "TEST_APP_NAME": "frame_sampling",
      "CACHE_BUSTER": "default_test"
    },
    "test_config": {
      "default_enable": true,
      "timeout": 30,
      "env": {
        "NVSTREAMMUX_ADAPTIVE_BATCHING": "yes"
      },
      "volumes": {
        "frame_sampling/models": "/workspace/models"
      },
      "cmd": [
        "--video-files", "34888cef-8d7a-4de9-80f2-7a6a11974d6f?frames=10&chunks=10"
      ],
      "error_detection": {
        "enabled": false,
        "patterns": [
          "[ERROR]",
          "[CRITICAL]"
        ]
      },
      "prerequisite_script": null
    }
  },
  {
    "name": "frame_sampling_on_streams",
    "description": "Test with default TensorRT and CUDA versions",
    "build_args": {
      "TEST_APP_NAME": "frame_sampling",
      "CACHE_BUSTER": "default_test"
    },
    "test_config": {
      "default_enable": false,
      "timeout": 30,
      "env": {
        "NVSTREAMMUX_ADAPTIVE_BATCHING": "yes"
      },
      "volumes": {
        "frame_sampling/models": "/workspace/models"
      },
      "cmd": [
        "--video-streams", "fcf490e3-a64b-4dc9-95db-dcdba90032b3?frames=10&duration=1000000000"
      ],
      "error_detection": {
        "enabled": false
      },
      "prerequisite_script": "./setup_rtsp_server.sh frame.jpg -m test -f 30 --daemon"
    }
  },
  {
    "name": "Output Types Compatibility Test",
    "description": "Test numpy array output type compatibility with simplified dummy backend",
    "build_args": {
      "TEST_APP_NAME": "output_types",
      "CACHE_BUSTER": "output_types_simplified",
      "SERVER_TYPE": "fastapi",
      "OPENAPI_SPEC": "builder/samples/dummy/openapi.yaml"
    },

    "test_config": {
      "default_enable": true,
      "timeout": 10,
      "volumes": {
        "output_types/models": "/workspace/models"
      },
      "env": {
        "DEBUG": "0"
      },
      "cmd": []
    }
  }
  ,
  {
    "name": "fastapi_concurrency_test",
    "description": "Build concurrency app and run threaded client",
    "build_args": {
      "TEST_APP_NAME": "concurrency",
      "CACHE_BUSTER": "concurrency_fastapi",
      "SERVER_TYPE": "fastapi",
      "OPENAPI_SPEC": "builder/samples/dummy/openapi.yaml"
    },
    "test_config": {
      "default_enable": true,
      "timeout": 30,
      "volumes": {
        "concurrency/models": "/workspace/models"
      },
      "cmd": []
    }
  }
]