[
  {
    "name": "qwen_pytorch_sw_decoder",
    "description": "Test Qwen2.5-VL-3B-Instruct with PyTorch backend and software decoder",
    "build_args": {
      "TEST_APP_NAME": "qwen",
      "CACHE_BUSTER": "qwen_pytorch_sw_test",
      "APP_YAML_PATH": "pytorch_qwen.yaml",
      "OUTPUT_DIR": ".",
      "PROCESSORS_PATH": "processors.py",
      "SERVER_TYPE": "fastapi",
      "OPENAPI_SPEC": "openapi.yaml"
    },
    "test_config": {
      "default_enable": true,
      "timeout": 600,
      "env": {
        "MODEL_REPO": "/workspace/model-repo",
        "NVIDIA_DRIVER_CAPABILITIES": "compute,utility,video,graphics",
        "HF_MODEL_NAME": "Qwen/Qwen2.5-VL-3B-Instruct"
      },
      "volumes": {
        "/tmp/model-repo": "/workspace/model-repo"
      },
      "ports": {
        "8000": "8000"
      },
      "payloads_path": ["payloads/images.jsonl"],
      "endpoint": "/v1/chat/completions",
      "prerequisite_script": null,
      "models": {
        "Qwen2.5-VL": {
          "source": "HF",
          "target": "/tmp/model-repo",
          "path": "Qwen/Qwen2.5-VL-3B-Instruct"
        }
      }
    }
  },
